server {
  listen 8080;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  # No caching — the app is tiny; env updates/code changes should be picked up
  # on the next page load without users having to hard-refresh.
  add_header Cache-Control "no-store" always;

  # Security headers (defense-in-depth)
  add_header X-Content-Type-Options "nosniff" always;
  add_header X-Frame-Options "DENY" always;
  add_header Referrer-Policy "no-referrer" always;
  add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' __VIKUNJA_URL__; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests" always;

  location / {
    try_files $uri $uri/ =404;
  }
}
